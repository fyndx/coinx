# Application Environment (development | preview | production)
EXPO_PUBLIC_APP_ENV=development
STRICT_ENV_VALIDATION=1

# API Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_BACKEND_URL=https://coinx-staging.coolify.fyndx.io

# Sentry
SENTRY_ORG=your_sentry_organization_slug
SENTRY_PROJECT=your_sentry_project_name
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Build-time only secrets (no EXPO_PUBLIC prefix - NOT accessible in src folder)
SECRET_KEY=my-secret-key
APP_BUILD_ONLY_VAR=build-only-value
